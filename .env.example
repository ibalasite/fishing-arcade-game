# Fishing Game Server — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fishing_game

# Redis
REDIS_URL=redis://localhost:6379

# Security (generate with: bash scripts/secrets/generate-secrets.sh)
JWT_SECRET=CHANGE_ME_run_generate_secrets_sh
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_run_generate_secrets_sh
HMAC_SECRET_KEY=CHANGE_ME_64_hex_chars_run_generate_secrets_sh

# Game Config
JACKPOT_CONTRIB_RATE=0.01
RTP_TARGET=0.93
MAX_PLAYERS_PER_ROOM=6
